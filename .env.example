# ---- App ----
# Set a path to serve under a subdirectory behind a reverse proxy, e.g.
#   BASE_URL=https://panovision.example.com/edl
# The app then mounts everything under /edl automatically. No path = served at root.
BASE_URL=http://localhost:3000
PORT=3000
# Address to bind. Use 127.0.0.1 behind a reverse proxy; 0.0.0.0 for containers.
BIND_ADDR=0.0.0.0
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me
# 1 if behind a TLS-terminating reverse proxy (nginx); 0 for local/docker testing.
TRUST_PROXY=0

# ---- Database ----
DATABASE_URL=postgres://edl:edlpassword@localhost:5432/edl

# ---- Auth mode ----
# 'local' = username/password from the LOCAL_ADMIN_* vars below (for testing).
# 'oidc'  = production SSO (requires the OIDC_* vars).
AUTH_MODE=local

# ---- Local auth (AUTH_MODE=local) ----
LOCAL_ADMIN_USER=admin
LOCAL_ADMIN_PASSWORD=ChangeMe123!

# ---- OIDC (AUTH_MODE=oidc) ----
OIDC_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=https://edl.example.com/callback
OIDC_SCOPES=openid profile email
# Comma-separated emails granted 'admin' on first login (others get 'editor').
ADMIN_EMAILS=
