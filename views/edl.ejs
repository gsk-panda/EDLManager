<%- include('partials/header') %>
<%
  function dtLocal(d){ if(!d) return ''; d=new Date(d); var p=function(n){return String(n).padStart(2,'0');};
    return d.getFullYear()+'-'+p(d.getMonth()+1)+'-'+p(d.getDate())+'T'+p(d.getHours())+':'+p(d.getMinutes()); }
  function isExpired(e){ return e.expires_at && new Date(e.expires_at) <= now; }
  var url = publicUrl(edl.slug);
%>

<div class="card">
  <p class="muted"><a href="/">&larr; All EDLs</a></p>
  <h1><%= edl.name %> <span class="pill"><%= edl.type %></span></h1>
  <p>
    <code><%= url %></code>
    <button class="btn sm" type="button" onclick="copyText('<%= url %>', this)">copy</button>
    &nbsp; <a class="btn sm" href="<%= url %>" target="_blank">view raw</a>
    &nbsp; <a class="btn sm" href="/edls/<%= edl.id %>/export">download</a>
  </p>

  <details>
    <summary class="muted">Edit list settings</summary>
    <form method="post" action="/edls/<%= edl.id %>" style="margin-top:10px;">
      <input type="hidden" name="_csrf" value="<%= csrf %>">
      <div class="row">
        <label>Name<br><input name="name" value="<%= edl.name %>"></label>
        <label>Description<br><input name="description" size="30" value="<%= edl.description || '' %>"></label>
        <label><br><input type="checkbox" name="enabled" <%= edl.enabled ? 'checked' : '' %>> enabled (served)</label>
        <button class="btn primary" type="submit">Save</button>
      </div>
    </form>
    <form method="post" action="/edls/<%= edl.id %>/delete" style="margin-top:8px;"
          onsubmit="return confirm('Delete this EDL and all its entries?');">
      <input type="hidden" name="_csrf" value="<%= csrf %>">
      <button class="btn danger sm" type="submit">Delete EDL</button>
    </form>
  </details>
</div>

<div class="card">
  <h2>Entries (<%= entries.length %>)</h2>
  <table>
    <thead><tr><th>Value</th><th>Comment</th><th>Expires</th><th>Status</th><th></th></tr></thead>
    <tbody>
    <% entries.forEach(function (e) { %>
      <tr<%= e.enabled ? '' : ' class="disabled-row"' %>>
        <td class="mono"><%= e.value %></td>
        <td><%= e.comment || '' %></td>
        <td class="<%= isExpired(e) ? 'expired' : '' %>">
          <%= e.expires_at ? new Date(e.expires_at).toLocaleString() : '—' %>
          <%= isExpired(e) ? '(expired)' : '' %>
        </td>
        <td><%= e.enabled ? (isExpired(e) ? 'hidden (expired)' : 'served') : 'disabled' %></td>
        <td>
          <form class="inline" method="post" action="/entries/<%= e.id %>/toggle">
            <input type="hidden" name="_csrf" value="<%= csrf %>">
            <button class="btn sm" type="submit"><%= e.enabled ? 'disable' : 'enable' %></button>
          </form>
          <form class="inline" method="post" action="/entries/<%= e.id %>/delete"
                onsubmit="return confirm('Delete this entry?');">
            <input type="hidden" name="_csrf" value="<%= csrf %>">
            <button class="btn danger sm" type="submit">delete</button>
          </form>
          <details style="display:inline-block;">
            <summary class="btn sm" style="list-style:none;">edit</summary>
            <form method="post" action="/entries/<%= e.id %>" style="margin-top:6px;">
              <input type="hidden" name="_csrf" value="<%= csrf %>">
              <div class="row">
                <label>Value<br><input class="mono" name="value" value="<%= e.value %>"></label>
                <label>Comment<br><input name="comment" value="<%= e.comment || '' %>"></label>
                <label>Expires<br><input type="datetime-local" name="expires_at" value="<%= dtLocal(e.expires_at) %>"></label>
                <button class="btn primary sm" type="submit">Save</button>
              </div>
            </form>
          </details>
        </td>
      </tr>
    <% }); %>
    </tbody>
  </table>
</div>

<div class="card">
  <h2>Add entry</h2>
  <form method="post" action="/edls/<%= edl.id %>/entries">
    <input type="hidden" name="_csrf" value="<%= csrf %>">
    <div class="row">
      <label>Value<br><input class="mono" name="value" required placeholder="<%= edl.type === 'ip' ? '203.0.113.0/24' : (edl.type === 'domain' ? '*.example.com' : 'example.com/path') %>"></label>
      <label>Comment<br><input name="comment" placeholder="optional"></label>
      <label>Expires <small>blank = never</small><input type="datetime-local" name="expires_at"></label>
      <button class="btn primary" type="submit">Add</button>
    </div>
  </form>
</div>

<div class="card">
  <h2>Bulk import</h2>
  <p class="muted">One entry per line. Blank lines and <code>#</code> comments are ignored; an inline <code># comment</code> is attached to the entry. Invalid and duplicate lines are reported, not silently dropped.</p>
  <form method="post" action="/edls/<%= edl.id %>/import">
    <input type="hidden" name="_csrf" value="<%= csrf %>">
    <textarea name="bulk" rows="8" placeholder="203.0.113.5 # known scanner&#10;198.51.100.0/24"></textarea>
    <p><button class="btn primary" type="submit">Import</button></p>
  </form>
</div>

<div class="card">
  <h2>Recent activity</h2>
  <% if (audit.length === 0) { %><p class="muted">No activity yet.</p><% } else { %>
  <table>
    <thead><tr><th>When</th><th>Who</th><th>Action</th><th>Detail</th></tr></thead>
    <tbody>
    <% audit.forEach(function (a) { %>
      <tr>
        <td class="muted"><%= new Date(a.created_at).toLocaleString() %></td>
        <td><%= a.actor_email || a.actor_sub %></td>
        <td><%= a.action %></td>
        <td class="mono" style="font-size:12px;"><%= a.detail ? JSON.stringify(a.detail) : '' %></td>
      </tr>
    <% }); %>
    </tbody>
  </table>
  <% } %>
</div>

<%- include('partials/footer') %>
